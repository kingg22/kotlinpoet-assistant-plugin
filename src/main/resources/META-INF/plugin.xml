<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.kotlin</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <errorHandler
            implementation="io.github.kingg22.kotlinpoet.assistant.infrastructure.reporting.PluginErrorReporting"/>

        <annotator
            language="kotlin"
            implementationClass="io.github.kingg22.kotlinpoet.assistant.infrastructure.annotator.KotlinPoetAnnotator"/>

        <!-- ─── Local Inspections ──────────────────────────────────────────────── -->

        <!--
            Missing argument: a placeholder in the format string has no corresponding argument.
            Runtime consequence: IllegalArgumentException from KotlinPoet.
        -->
        <localInspection
            language="kotlin"
            shortName="KotlinPoetMissingArgument"
            bundle="messages.MyBundle"
            key="inspection.missing.argument.display.name"
            groupBundle="messages.MyBundle"
            groupKey="inspection.group.name"
            enabledByDefault="true"
            level="ERROR"
            implementationClass="io.github.kingg22.kotlinpoet.assistant.infrastructure.inspection.inspections.MissingArgumentInspection"/>

        <!--
            Extra argument: an argument was supplied that has no matching placeholder.
            Runtime consequence: IllegalArgumentException from KotlinPoet.
        -->
        <localInspection
            language="kotlin"
            shortName="KotlinPoetExtraArgument"
            bundle="messages.MyBundle"
            key="inspection.extra.argument.display.name"
            groupBundle="messages.MyBundle"
            groupKey="inspection.group.name"
            enabledByDefault="true"
            level="ERROR"
            implementationClass="io.github.kingg22.kotlinpoet.assistant.infrastructure.inspection.inspections.ExtraArgumentInspection"/>

        <!--
            Type mismatch: the argument's type is incompatible with the placeholder kind.
            Severity varies per placeholder (WARNING for %T / %N / %M, INFORMATION for %S / %P).
        -->
        <localInspection
            language="kotlin"
            shortName="KotlinPoetTypeMismatch"
            bundle="messages.MyBundle"
            key="inspection.type.mismatch.display.name"
            groupBundle="messages.MyBundle"
            groupKey="inspection.group.name"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="io.github.kingg22.kotlinpoet.assistant.infrastructure.inspection.inspections.TypeMismatchInspection"/>

        <!--
            Named argument case: a key in the argument map does not start with a lowercase letter.
            KotlinPoet requires keys to match [a-z]+[\w_]* — violating this causes an IllegalArgumentException at runtime.
        -->
        <localInspection
            language="kotlin"
            shortName="KotlinPoetNamedCase"
            bundle="messages.MyBundle"
            key="inspection.named.case.display.name"
            groupBundle="messages.MyBundle"
            groupKey="inspection.group.name"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="io.github.kingg22.kotlinpoet.assistant.infrastructure.inspection.inspections.NamedCaseInspection"/>

        <!--
            Format string syntax: dangling %, unknown placeholder type (%Z), invalid positional index (%0L).
            Quick fixes are available for all three cases.
        -->
        <localInspection
            language="kotlin"
            shortName="KotlinPoetFormatSyntax"
            bundle="messages.MyBundle"
            key="inspection.format.syntax.display.name"
            groupBundle="messages.MyBundle"
            groupKey="inspection.group.name"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="io.github.kingg22.kotlinpoet.assistant.infrastructure.inspection.inspections.FormatSyntaxInspection"/>

        <!-- ─── End Local Inspections ──────────────────────────────────────────── -->

        <psi.symbolReferenceProvider
            hostLanguage="kotlin"
            hostElementClass="org.jetbrains.kotlin.psi.KtStringTemplateExpression"
            targetClass="io.github.kingg22.kotlinpoet.assistant.infrastructure.references.KotlinPoetArgumentSymbol"
            implementationClass="io.github.kingg22.kotlinpoet.assistant.infrastructure.references.KotlinPoetReferenceProvider"/>

        <completion.contributor
            language="kotlin"
            implementationClass="io.github.kingg22.kotlinpoet.assistant.infrastructure.completion.KotlinPoetCompletionContributor"/>

        <completion.confidence
            language="kotlin"
            order="first"
            implementationClass="io.github.kingg22.kotlinpoet.assistant.infrastructure.completion.KotlinPoetCompletionConfidence"/>

        <typedHandler
            order="first"
            implementation="io.github.kingg22.kotlinpoet.assistant.infrastructure.completion.KotlinPoetTypedHandler"/>

        <platform.backend.documentation.targetProvider
            implementation="io.github.kingg22.kotlinpoet.assistant.infrastructure.documentation.KotlinPoetDocumentationTargetProvider"/>

        <searcher
            forClass="com.intellij.find.usages.api.UsageSearchParameters"
            implementationClass="io.github.kingg22.kotlinpoet.assistant.infrastructure.references.KotlinPoetFormatUsageSearcher"/>
    </extensions>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK1="false" supportsK2="true" />
    </extensions>
</idea-plugin>
