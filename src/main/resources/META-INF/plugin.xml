<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.kotlin</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <errorHandler
            implementation="io.github.kingg22.kotlinpoet.assistant.infrastructure.reporting.PluginErrorReporting"/>

        <annotator
            language="kotlin"
            implementationClass="io.github.kingg22.kotlinpoet.assistant.infrastructure.annotator.KotlinPoetAnnotator"/>

        <psi.symbolReferenceProvider
            hostLanguage="kotlin"
            hostElementClass="org.jetbrains.kotlin.psi.KtStringTemplateExpression"
            targetClass="io.github.kingg22.kotlinpoet.assistant.infrastructure.references.KotlinPoetArgumentSymbol"
            implementationClass="io.github.kingg22.kotlinpoet.assistant.infrastructure.references.KotlinPoetReferenceProvider"/>

        <completion.contributor
            language="kotlin"
            implementationClass="io.github.kingg22.kotlinpoet.assistant.infrastructure.completion.KotlinPoetCompletionContributor"/>

        <completion.confidence
            language="kotlin"
            order="first"
            implementationClass="io.github.kingg22.kotlinpoet.assistant.infrastructure.completion.KotlinPoetCompletionConfidence"/>

        <typedHandler
            order="first"
            implementation="io.github.kingg22.kotlinpoet.assistant.infrastructure.completion.KotlinPoetTypedHandler"/>
    </extensions>

    <extensions defaultExtensionNs="org.jetbrains.kotlin">
        <supportsKotlinPluginMode supportsK1="false" supportsK2="true" />
    </extensions>
</idea-plugin>
